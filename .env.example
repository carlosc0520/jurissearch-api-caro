# ============================================
# JURIS SEARCH API - Environment Variables
# ============================================

# Server Configuration
PORT=3000
# NODE_ENV=development
NODE_ENV=production
DOMINIO=http://localhost:8080

# JWT Security Keys (REQUIRED - Minimum 32 characters each)
# Generate strong keys: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your_secret_key_minimum_32_characters_here_replace_this_with_strong_key
REFRESH_TOKEN_SECRET=your_refresh_token_secret_different_from_secret_key_minimum_32_chars
SECRET_KEY_SOLICITUD=your_solicitud_secret_key_minimum_32_characters_here

# Database Configuration (MySQL)
USE_SQL_SESSIONS=true
DB_SERVER=SQL5113.site4now.net
DB_PORT=1433
DB_USER=db_a9ec8e_jurissearchpro_admin
DB_PASSWORD=ING052001
DB_NAME=db_a9ec8e_jurissearchpro
DB_TRUST_CERT=true


# SQL Server Configuration (For Session Management)
# Set USE_SQL_SESSIONS=false to disable SQL Server and use JSON files
USE_SQL_SESSIONS=true

# Development Environment
DB_SERVER=SQL5113.site4now.net   # SQL Server host
DB_PORT=1433                      # SQL Server port
# DB_USER=db_a9ec8e_jurissearchdev_admin
# DB_PASSWORD=ING052001
# DB_NAME=db_a9ec8e_jurissearchdev

DB_TRUST_CERT=true               # Trust self-signed certificates (for development only)

# AWS S3 Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Email Service Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@domain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@jurissearch.com

# OAuth Configuration (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth Configuration (LinkedIn)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/auth/linkedin/callback

# Token Configuration (in seconds)
ACCESS_TOKEN_EXPIRY=900          # 15 minutes (default: 900 seconds)
REFRESH_TOKEN_EXPIRY=604800      # 7 days (default: 604800 seconds)
RECOVERY_TOKEN_EXPIRY=1800       # 30 minutes (default: 1800 seconds)

# Session Configuration
MAX_SESSIONS_PER_USER=5          # Maximum concurrent sessions per user
SESSION_CLEANUP_INTERVAL=3600000 # Cleanup interval in ms (1 hour)

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000          # 15 minutes in ms

# CORS
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=900000         # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100      # Max requests per window

# File Upload
MAX_FILE_SIZE=10485760           # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Logging
LOG_LEVEL=debug                  # debug, info, warn, error
LOG_FILE_PATH=./logs

# ============================================
# IMPORTANT SECURITY NOTES:
# ============================================
# 1. NEVER commit this file with actual values to version control
# 2. Use different SECRET_KEY and REFRESH_TOKEN_SECRET
# 3. Generate strong random keys (minimum 32 characters)
# 4. Rotate keys periodically in production
# 5. Use environment-specific .env files (.env.development, .env.production)
# ============================================
